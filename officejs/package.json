{
  "name": "excel-llm-addin",
  "version": "0.1.0",
  "description": "Connect Excel to multiple LLM providers via Office.js custom functions and a task pane.",
  "license": "AGPL-3.0-only",
  "author": "ExcelLLM contributors",
  "private": true,
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "watch": "webpack --mode development --watch",
    "dev-server": "webpack serve --mode development",
    "start": "office-addin-debugging start manifest.xml",
    "stop": "office-addin-debugging stop manifest.xml",
    "validate": "office-addin-manifest validate manifest.xml",
    "typecheck": "tsc --noEmit",
    "harness:smoke": "node tools/drive-harness.cjs",
    "check:ui": "node tools/check-ui.cjs"
  },
  "dependencies": {
    "core-js": "^3.36.0"
  },
  "devDependencies": {
    "@types/custom-functions-runtime": "^1.6.13",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.30",
    "@types/office-js": "^1.0.377",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^6.10.0",
    "custom-functions-metadata-plugin": "^1.2.6",
    "html-loader": "^5.0.0",
    "html-webpack-plugin": "^5.6.0",
    "jest": "^29.7.0",
    "mini-css-extract-plugin": "^2.10.2",
    "office-addin-debugging": "^5.1.5",
    "office-addin-dev-certs": "^1.13.0",
    "office-addin-manifest": "^1.13.0",
    "playwright-core": "^1.61.1",
    "style-loader": "^3.3.4",
    "ts-jest": "^29.1.2",
    "ts-loader": "^9.5.1",
    "typescript": "^5.4.5",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.4"
  }
}
